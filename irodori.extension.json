{
  "$schema": "https://irodori.dev/schemas/irodori.extension.schema.json",
  "manifestVersion": 1,
  "id": "irodori.milvus",
  "name": "Milvus Connector",
  "version": "0.1.0",
  "publisher": "irodori",
  "description": "Milvus Connector contributes the Milvus database connector through the native connector ABI.",
  "license": "MIT OR 0BSD",
  "repository": "https://github.com/hjosugi/irodori-extension-milvus",
  "apiVersion": "0.1",
  "runtime": "native",
  "entry": "dist/native",
  "permissions": [
    "connections:read",
    "connections:write",
    "queries:run",
    "metadata:read",
    "native",
    "connectors"
  ],
  "contributes": {
    "connectors": [
      {
        "id": "milvus.connector",
        "engine": "milvus",
        "label": "Milvus",
        "aliases": [
          "milvus",
          "Milvus"
        ],
        "defaultPort": 19530,
        "wire": "milvus",
        "module": "milvus.driver",
        "features": [
          "metadata"
        ]
      }
    ]
  },
  "capabilities": {
    "nativeModules": [
      {
        "id": "milvus.driver",
        "path": "dist/native",
        "platforms": [
          "windowsX64",
          "windowsArm64",
          "macosX64",
          "macosArm64",
          "linuxX64",
          "linuxArm64"
        ]
      }
    ]
  },
  "dev": {
    "watch": [
      "src",
      "connector.config.json",
      "irodori.extension.json"
    ]
  }
}
